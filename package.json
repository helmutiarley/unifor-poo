{
  "name": "unifor-poo",
  "version": "1.0.0",
  "description": "Unifor POO",
  "license": "ISC",
  "author": "Helmut",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "npm run migrate:deploy && node server.js",
    "dev": "npm run migrate:deploy && node scripts/run-with-db-url.js nodemon server.js",
    "migrate:deploy": "node scripts/run-with-db-url.js prisma migrate deploy",
    "migrate:up": "node scripts/run-with-db-url.js prisma migrate dev",
    "migrate:reset": "node scripts/run-with-db-url.js prisma migrate reset --force",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
